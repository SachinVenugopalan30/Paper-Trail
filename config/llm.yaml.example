# LLM Provider Configuration
# Copy to config/llm.yaml and fill in your API keys (or set environment variables)

providers:
  openai:
    enabled: false
    api_key: ${OPENAI_API_KEY}       # set env var or paste key here
    model: gpt-4-turbo-preview
    max_tokens: 4096
    temperature: 0.1

  claude:
    enabled: false
    api_key: ${ANTHROPIC_API_KEY}    # set env var or paste key here
    model: claude-3-sonnet-20240229
    max_tokens: 4096
    temperature: 0.1

  gemini:
    enabled: false
    api_key: ${GEMINI_API_KEY}       # set env var or paste key here
    model: gemini-pro
    max_tokens: 4096
    temperature: 0.1

  ollama:
    enabled: true                    # free, local — recommended default
    base_url: http://localhost:11434
    model: gemma3:latest
    max_tokens: 4096
    temperature: 0.1

  vllm:
    enabled: false
    base_url: http://localhost:8000/v1
    api_key: not-needed
    model: meta-llama/Llama-3.2-3B-Instruct
    max_tokens: 4096
    temperature: 0.1

# Default provider for entity/relation extraction
default_provider: ollama

# Extraction settings
extraction:
  chunk_size: 1000
  chunk_overlap: 200
  max_chunks_per_document: 50

# Entity types to extract
entity_types:
  - Document
  - Person
  - Organization
  - Technology
  - Topic
  - Reference
  - Location

# Relation types to extract
relation_types:
  - MENTIONS_PERSON
  - MENTIONS_ORG
  - MENTIONS_TECH
  - COVERS_TOPIC
  - HAS_REFERENCE
  - HAS_LOCATION
  - AFFILIATED_WITH
  - RELATED_TO
  - LOCATED_AT
